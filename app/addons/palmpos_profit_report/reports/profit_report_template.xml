<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Definition -->
    <record id="action_report_pos_profit" model="ir.actions.report">
        <field name="name">Profit Report</field>
        <field name="model">pos.profit.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">palmpos_profit_report.report_profit_template</field>
        <field name="report_file">palmpos_profit_report.report_profit_template</field>
        <field name="binding_model_id" ref="model_pos_profit_report"/>
        <field name="binding_type">report</field>
    </record>

    <!-- PDF Template -->
    <template id="report_profit_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                    <!-- Report Header -->
                    <div class="text-center mb-4">
                        <h2>Profit &amp; Loss Report</h2>
                            <h4>
                                <t t-if="doc.report_type == 'product'">By Product</t>
                                <t t-elif="doc.report_type == 'customer'">By Customer</t>
                                <t t-else="">By Date Range</t>
                            </h4>
                            <p>
                                <strong>Period:</strong> 
                                <span t-field="doc.date_from"/> to <span t-field="doc.date_to"/>
                            </p>
                        </div>

                        <!-- Report Table -->
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Sales</th>
                                    <th class="text-end">Cost</th>
                                    <th class="text-end">Tax</th>
                                    <th class="text-end">Discount</th>
                                    <th class="text-end">Profit</th>
                                    <th class="text-end">Margin %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end"><span t-field="line.sales_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.cost_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.tax_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.discount_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end">
                                        <span t-field="line.profit_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <td class="text-end"><t t-esc="'%.2f' % line.profit_margin"/>%</td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td><strong>TOTAL</strong></td>
                                    <td class="text-end"><t t-esc="'%.2f' % sum(doc.line_ids.mapped('quantity'))"/></td>
                                    <td class="text-end"><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="doc.total_tax" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="doc.total_discount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end">
                                        <span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <td class="text-end"><t t-esc="'%.2f' % doc.profit_margin"/>%</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Summary Box -->
                        <div class="row mt-4">
                            <div class="col-6 offset-6">
                                <table class="table table-sm">
                                    <tr>
                                        <td><strong>Total Sales:</strong></td>
                                        <td class="text-end"><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Total Cost:</strong></td>
                                        <td class="text-end"><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    </tr>
                                    <tr class="border-top">
                                        <td><strong>Net Profit:</strong></td>
                                        <td class="text-end"><strong><span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                    </tr>
                                    <tr>
                                        <td><strong>Profit Margin:</strong></td>
                                        <td class="text-end"><strong><t t-esc="'%.2f' % doc.profit_margin"/>%</strong></td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
            </t>
        </t>
    </template>
</odoo>
