<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Definition -->
    <record id="action_report_pos_profit" model="ir.actions.report">
        <field name="name">Profit Report</field>
        <field name="model">pos.profit.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">palmpos_profit_report.report_profit_template</field>
        <field name="report_file">palmpos_profit_report.report_profit_template</field>
        <field name="binding_model_id" ref="model_pos_profit_report"/>
        <field name="binding_type">report</field>
    </record>

    <!-- PDF Template -->
    <template id="report_profit_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page">
                        <style>
                            .profit-report-table {
                                width: 100%;
                                border-collapse: collapse;
                                margin-bottom: 20px;
                            }
                            .profit-report-table th {
                                font-weight: bold;
                                padding: 8px;
                                text-align: left;
                                border-bottom: 2px solid #000;
                            }
                            .profit-report-table td {
                                padding: 6px 8px;
                                border-bottom: 1px solid #ddd;
                            }
                            .profit-report-table tfoot td {
                                font-weight: bold;
                                border-top: 2px solid #000;
                                border-bottom: 2px solid #000;
                            }
                            .text-right {
                                text-align: right;
                            }
                            .summary-table {
                                width: 40%;
                                margin-left: auto;
                                margin-top: 30px;
                            }
                            .summary-table td {
                                padding: 6px 8px;
                            }
                        </style>
                        
                        <!-- Report Header -->
                        <div style="text-align: center; margin-bottom: 30px;">
                            <h2 style="margin-bottom: 10px;">Profit &amp; Loss Report</h2>
                            <h4 style="margin-bottom: 10px;">
                                <t t-if="doc.report_type == 'product'">By Product</t>
                                <t t-elif="doc.report_type == 'customer'">By Customer</t>
                                <t t-else="">By Date Range</t>
                            </h4>
                            <p style="margin: 5px 0;">
                                <strong>Period:</strong> 
                                <span t-field="doc.date_from"/> to <span t-field="doc.date_to"/>
                            </p>
                        </div>

                        <!-- Report Table -->
                        <table class="profit-report-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th class="text-right">Qty</th>
                                    <th class="text-right">Sales</th>
                                    <th class="text-right">Cost</th>
                                    <th class="text-right">Tax</th>
                                    <th class="text-right">Discount</th>
                                    <th class="text-right">Profit</th>
                                    <th class="text-right">Margin %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line">
                                    <td><span t-field="line.name"/></td>
                                    <td class="text-right"><span t-field="line.quantity"/></td>
                                    <td class="text-right"><span t-field="line.sales_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="line.cost_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="line.tax_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="line.discount_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right">
                                        <span t-field="line.profit_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <td class="text-right"><t t-esc="'%.2f' % line.profit_margin"/>%</td>
                                </tr>
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td><strong>TOTAL</strong></td>
                                    <td class="text-right"><t t-esc="'%.2f' % sum(doc.line_ids.mapped('quantity'))"/></td>
                                    <td class="text-right"><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="doc.total_tax" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right"><span t-field="doc.total_discount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-right">
                                        <span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <td class="text-right"><t t-esc="'%.2f' % doc.profit_margin"/>%</td>
                                </tr>
                            </tfoot>
                        </table>

                        <!-- Summary Box -->
                        <table class="summary-table">
                            <tr>
                                <td><strong>Total Sales:</strong></td>
                                <td class="text-right"><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                            </tr>
                            <tr>
                                <td><strong>Total Cost:</strong></td>
                                <td class="text-right"><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                            </tr>
                            <tr style="border-top: 2px solid #000;">
                                <td><strong>Net Profit:</strong></td>
                                <td class="text-right"><strong><span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                            </tr>
                            <tr>
                                <td><strong>Profit Margin:</strong></td>
                                <td class="text-right"><strong><t t-esc="'%.2f' % doc.profit_margin"/>%</strong></td>
                            </tr>
                        </table>
                    </div>
            </t>
        </t>
    </template>
</odoo>
