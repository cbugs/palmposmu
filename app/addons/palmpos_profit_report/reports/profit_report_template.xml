<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PDF Report Definition -->
    <record id="action_report_pos_profit" model="ir.actions.report">
        <field name="name">Profit Report</field>
        <field name="model">pos.profit.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">palmpos_profit_report.report_profit_template</field>
        <field name="report_file">palmpos_profit_report.report_profit_template</field>
        <field name="binding_model_id" ref="model_pos_profit_report"/>
        <field name="binding_type">report</field>
    </record>

    <!-- PDF Template -->
    <template id="report_profit_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="company" t-value="env.company"/>
                <t t-call="web.basic_layout">
                    <div class="page">
                        <!-- Report Header -->
                        <div class="bg-secondary p-3" id="header">
                            <div class="row">
                                <div class="col-3 d-flex flex-column justify-content-center">
                                    <br/>
                                    <br/>
                                    <div class="text-start" style="font-size:0.85rem;">
                                        <span t-esc="company.name"/>
                                        <address class="mb-0 text-muted" t-field="env.company.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}"/>
                                    </div>
                                </div>
                                <div class="col-6 text-center">
                                    <h2>Profit &amp; Loss Report</h2>
                                    <h4>
                                        <t t-if="doc.report_type == 'product'">By Product</t>
                                        <t t-elif="doc.report_type == 'customer'">By Customer</t>
                                        <t t-else="">By Date Range</t>
                                    </h4>
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12 text-end mt-2">
                                <span class="badge bg-light text-dark border border-dark p-2">
                                    <t t-set="date_format" t-value="env['res.lang']._get_data(code=env.user.lang).date_format"/>
                                    <strong>Period: <span t-field="doc.date_from"/> to <span t-field="doc.date_to"/></strong>
                                </span>
                            </div>
                        </div>
                        <br/>
                        <br/>

                        <!-- Report Table -->
                        <h6 class="bg-secondary p-1 fw-bold">Profit Details</h6>
                        <table class="table table-sm table-borderless">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Sales</th>
                                    <th class="text-end">Cost</th>
                                    <th class="text-end">Tax</th>
                                    <th class="text-end">Discount</th>
                                    <th class="text-end">Profit</th>
                                    <th class="text-end">Margin %</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.line_ids" t-as="line" class="border-bottom border-secondary">
                                    <td class="ps-2 fw-bold"><span t-field="line.name"/></td>
                                    <td class="text-end"><span t-field="line.quantity"/></td>
                                    <td class="text-end"><span t-field="line.sales_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.cost_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.tax_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end"><span t-field="line.discount_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    <td class="text-end">
                                        <span t-field="line.profit_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                    </td>
                                    <td class="text-end"><t t-esc="'%.2f' % line.profit_margin"/>%</td>
                                </tr>
                                <tr>
                                    <td><strong>TOTAL</strong></td>
                                    <td class="text-end"><strong><t t-esc="'%.2f' % sum(doc.line_ids.mapped('quantity'))"/></strong></td>
                                    <td class="text-end"><strong><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                    <td class="text-end"><strong><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                    <td class="text-end"><strong><span t-field="doc.total_tax" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                    <td class="text-end"><strong><span t-field="doc.total_discount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                    <td class="text-end">
                                        <strong><span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong>
                                    </td>
                                    <td class="text-end"><strong><t t-esc="'%.2f' % doc.profit_margin"/>%</strong></td>
                                </tr>
                            </tbody>
                        </table>
                        <br/>

                        <!-- Summary Box -->
                        <h6 class="bg-secondary p-1 fw-bold w-50 ms-auto">Summary</h6>
                        <table class="table table-sm table-borderless w-50 ms-auto">
                            <tbody>
                                <tr class="border-bottom border-secondary">
                                    <td class="ps-2 fw-bold">Total Sales:</td>
                                    <td class="text-end"><span t-field="doc.total_sales" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                </tr>
                                <tr class="border-bottom border-secondary">
                                    <td class="ps-2 fw-bold">Total Cost:</td>
                                    <td class="text-end"><span t-field="doc.total_cost" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                </tr>
                                <tr class="border-bottom border-secondary">
                                    <td class="ps-2 fw-bold">Net Profit:</td>
                                    <td class="text-end"><strong><span t-field="doc.total_profit" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></strong></td>
                                </tr>
                                <tr>
                                    <td class="ps-2 fw-bold">Profit Margin:</td>
                                    <td class="text-end"><strong><t t-esc="'%.2f' % doc.profit_margin"/>%</strong></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
