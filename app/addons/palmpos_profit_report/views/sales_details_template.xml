<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override POS Sales Details Template -->
    <template id="pos_session_sales_details" inherit_id="point_of_sale.pos_session_sales_details">
        <xpath expr="//div[@class='page']" position="replace">
            <div class="page">
                <style>
                    .sales-detail-table {
                        width: 100%;
                        border-collapse: collapse;
                        margin-bottom: 20px;
                    }
                    .sales-detail-table th {
                        font-weight: bold;
                        padding: 8px;
                        text-align: left;
                        border-bottom: 2px solid #000;
                    }
                    .sales-detail-table td {
                        padding: 6px 8px;
                        border-bottom: 1px solid #ddd;
                    }
                    .sales-detail-table tfoot td {
                        font-weight: bold;
                        border-top: 2px solid #000;
                        border-bottom: 2px solid #000;
                    }
                    .section-header {
                        font-weight: bold;
                        font-size: 1.1em;
                        margin-top: 25px;
                        margin-bottom: 10px;
                        padding-bottom: 5px;
                        border-bottom: 2px solid #000;
                    }
                    .text-right {
                        text-align: right;
                    }
                    .report-header {
                        text-align: center;
                        margin-bottom: 30px;
                    }
                    .company-info {
                        margin-bottom: 20px;
                    }
                </style>
                
                <!-- Header -->
                <div class="report-header">
                    <h2>
                        Sales Details
                        <t t-if="state == 'closed'">Z</t>
                        <t t-else="">X</t>
                    </h2>
                    <t t-if="session_name">
                        <p style="margin: 5px 0;">Session ID: <span t-out="session_name"/></p>
                    </t>
                    <t t-set="date_format" t-value="env['res.lang']._get_data(code=env.user.lang).date_format"/>
                    <p style="margin: 5px 0;"><strong>As of <span t-esc="context_timestamp(datetime.datetime.now()).strftime(date_format)"/></strong></p>
                    <t t-if="date_start and date_stop">
                        <p style="margin: 5px 0;">
                            <span t-out="date_start" t-options="{'widget': 'datetime'}"/> - <span t-out="date_stop" t-options="{'widget': 'datetime'}"/>
                        </p>
                    </t>
                </div>

                <div class="company-info">
                    <strong><span t-esc="company.name"/></strong>
                    <div t-field="env.company.partner_id" t-options="{'widget': 'contact', 'fields': ['address'], 'no_marker': True}"/>
                </div>

                <!-- Sales Section -->
                <div t-if="products">
                    <div class="section-header">Sales</div>
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-right">Qty</th>
                                <th class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="products" t-as="category">
                                <tr style="font-weight: bold;">
                                    <td><span t-out="category['name']"/></td>
                                    <td class="text-right"><span t-out="category['qty']"/></td>
                                    <td class="text-right">
                                        <t t-if="currency['position']">
                                            <span t-out="category['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                        </t>
                                        <t t-else="">
                                            <span t-out="currency['symbol']"/><span t-out="category['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr t-foreach="category['products']" t-as="line">
                                    <td style="padding-left: 30px;"><span t-out="line['product_name']"/><span t-if="line['combo_products_label']" t-out="line['combo_products_label']"/></td>
                                    <td class="text-right">
                                        <span t-out="line['quantity']"/>
                                        <t t-if="line['uom'] != 'Units'">
                                            <span t-out="line['uom']"/>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="currency['position']">
                                            <span t-out="line['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                        </t>
                                        <t t-else="">
                                            <span t-out="currency['symbol']"/><span t-out="line['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                        </t>
                                        <t t-if="line['discount'] != 0">
                                            (Disc: <span t-out="line['discount']"/>%)
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-right"><span t-out="products_info['qty']"/></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="products_info['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="products_info['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Taxes Section -->
                <div t-if="taxes" style="width: 50%; margin-left: auto;">
                    <div class="section-header">Taxes on Sales</div>
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Tax</th>
                                <th class="text-right">Tax Amount</th>
                                <th class="text-right">Base Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="taxes" t-as="tax">
                                <td><span t-out="tax['name']"/></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="tax['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="tax['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="tax['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="tax['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="taxes_info['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="taxes_info['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="taxes_info['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="taxes_info['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Refunds Section -->
                <div t-if="refund_products">
                    <div class="section-header">Refunds</div>
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th class="text-right">Qty</th>
                                <th class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="refund_products" t-as="category">
                                <tr style="font-weight: bold;">
                                    <td><span t-out="category['name']"/></td>
                                    <td class="text-right"><span t-out="category['qty']"/></td>
                                    <td class="text-right">
                                        <t t-if="currency['position']">
                                            <span t-out="category['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                        </t>
                                        <t t-else="">
                                            <span t-out="currency['symbol']"/><span t-out="category['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                        </t>
                                    </td>
                                </tr>
                                <tr t-foreach="category['products']" t-as="line">
                                    <td style="padding-left: 30px;"><span t-out="line['product_name']"/><span t-if="line['combo_products_label']" t-out="line['combo_products_label']"/></td>
                                    <td class="text-right">
                                        <span t-out="line['quantity']"/>
                                        <t t-if="line['uom'] != 'Units'">
                                            <span t-out="line['uom']"/>
                                        </t>
                                    </td>
                                    <td class="text-right">
                                        <t t-if="currency['position']">
                                            <span t-out="line['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                        </t>
                                        <t t-else="">
                                            <span t-out="currency['symbol']"/><span t-out="line['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                        </t>
                                        <t t-if="line['discount'] != 0">
                                            (Disc: <span t-out="line['discount']"/>%)
                                        </t>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-right"><span t-out="refund_info['qty']"/></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="refund_info['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="refund_info['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Refund Taxes Section -->
                <div t-if="refund_taxes" style="width: 50%; margin-left: auto;">
                    <div class="section-header">Taxes on Refunds</div>
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Tax</th>
                                <th class="text-right">Tax Amount</th>
                                <th class="text-right">Base Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="refund_taxes" t-as="tax">
                                <td><span t-out="tax['name']"/></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="tax['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="tax['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="tax['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="tax['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="refund_taxes_info['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="refund_taxes_info['tax_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="refund_taxes_info['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="refund_taxes_info['base_amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Payments Section -->
                <div t-if="payments" style="width: 50%; margin-left: auto;">
                    <div class="section-header">Payments</div>
                    <table class="sales-detail-table">
                        <tbody>
                            <tr t-foreach="payments" t-as="payment">
                                <td><span t-out="payment['name']"/></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="payment['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="payment['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td><strong>Total</strong></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="currency['total_paid']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="currency['total_paid']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                    <t t-if="show_payment_per_method">
                        <table class="sales-detail-table" style="margin-top: 10px;">
                            <tbody>
                                <tr t-foreach="payments_per_method" t-as="ppm">
                                    <td><span t-out="ppm['name']"/></td>
                                    <td class="text-right">
                                        <t t-if="currency['position']">
                                            <span t-out="ppm['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                        </t>
                                        <t t-else="">
                                            <span t-out="currency['symbol']"/><span t-out="ppm['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                        </t>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>

                <!-- Discounts Section -->
                <div style="margin-top: 20px;">
                    <div class="section-header">Discounts</div>
                    <p><strong>Number of discounts:</strong> <span t-out="discount_number"/></p>
                    <p>
                        <strong>Amount of discounts:</strong>
                        <t t-if="currency['position']">
                            <span t-out="discount_amount" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                        </t>
                        <t t-else="">
                            <span t-out="currency['symbol']"/><span t-out="discount_amount" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                        </t>
                    </p>
                </div>

                <!-- Invoices Section -->
                <div t-if="invoiceTotal">
                    <div class="section-header">Invoices</div>
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Invoice</th>
                                <th>Order Reference</th>
                                <th class="text-right">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="invoiceList" t-as="invoiceSession">
                                <t t-if="invoiceSession['invoices']">
                                    <tr t-foreach="invoiceSession['invoices']" t-as="invoice">
                                        <td><span t-out="invoice['name']"/></td>
                                        <td><span t-out="invoice['order_ref']"/></td>
                                        <td class="text-right">
                                            <t t-if="currency['position']">
                                                <span t-out="invoice['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                            </t>
                                            <t t-else="">
                                                <span t-out="currency['symbol']"/><span t-out="invoice['total']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                            </t>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="2"><strong>Total</strong></td>
                                <td class="text-right">
                                    <t t-if="currency['position']">
                                        <span t-out="invoiceTotal" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                    </t>
                                    <t t-else="">
                                        <span t-out="currency['symbol']"/><span t-out="invoiceTotal" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                    </t>
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <!-- Session Control Section -->
                <div style="margin-top: 20px;">
                    <div class="section-header">Session Control</div>
                    <p>
                        <strong>Total:
                            <t t-if="currency['position']">
                                <span t-out="currency['total_paid']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                            </t>
                            <t t-else="">
                                <span t-out="currency['symbol']"/><span t-out="currency['total_paid']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                            </t>
                        </strong>
                    </p>
                    <p><strong>Number of transactions: <span t-out="nbr_orders"/></strong></p>
                    
                    <table class="sales-detail-table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th></th>
                                <th class="text-right">Expected</th>
                                <th t-if="(state == 'closed' or state == 'multiple') and payments" class="text-right">Counted</th>
                                <th t-if="(state == 'closed' or state == 'multiple') and payments" class="text-right">Difference</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="payments" t-as="method">
                                <t t-if="method['count']">
                                    <tr style="font-weight: bold;">
                                        <td><span t-out="method['name']"/></td>
                                        <td></td>
                                        <td class="text-right">
                                            <t t-if="currency['position']">
                                                <span t-out="method['final_count']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                            </t>
                                            <t t-else="">
                                                <span t-out="currency['symbol']"/><span t-out="method['final_count']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                            </t>
                                        </td>
                                        <td t-if="(state == 'closed' or state == 'multiple') and payments" class="text-right">
                                            <t t-if="currency['position']">
                                                <span t-out="method['money_counted']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                            </t>
                                            <t t-else="">
                                                <span t-out="currency['symbol']"/><span t-out="method['money_counted']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                            </t>
                                        </td>
                                        <td t-if="(state == 'closed' or state == 'multiple') and payments" class="text-right">
                                            <t t-if="currency['position']">
                                                <span t-out="method['money_difference']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                            </t>
                                            <t t-else="">
                                                <span t-out="currency['symbol']"/><span t-out="method['money_difference']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                            </t>
                                        </td>
                                    </tr>
                                    <tr t-if="(state == 'closed' or state == 'multiple') and payments" t-foreach="method['cash_moves']" t-as="move">
                                        <td></td>
                                        <td><span t-out="move['name']"/></td>
                                        <td class="text-right">
                                            <t t-if="currency['position']">
                                                <span t-out="move['amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/><span t-out="currency['symbol']"/>
                                            </t>
                                            <t t-else="">
                                                <span t-out="currency['symbol']"/><span t-out="move['amount']" t-options="{'widget': 'float', 'precision': currency['precision']}"/>
                                            </t>
                                        </td>
                                        <td></td>
                                        <td></td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>

                    <div t-if="opening_note or closing_note" style="margin-top: 20px;">
                        <p t-if="opening_note">
                            <strong>Opening of session note:</strong><br/>
                            <span t-out="opening_note" t-options="{'widget': 'text'}"/>
                        </p>
                        <p t-if="closing_note">
                            <strong>End of session note:</strong><br/>
                            <span t-out="closing_note" t-options="{'widget': 'text'}"/>
                        </p>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
