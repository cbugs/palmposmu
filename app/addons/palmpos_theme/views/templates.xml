<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Override the scoped app page to use PalmPOS logo as favicon -->
    <template id="webclient_scoped_app_custom" inherit_id="web.webclient_scoped_app" name="PalmPOS Scoped App Favicon">
        <xpath expr="//t[@t-set='x_icon']" position="replace">
            <t t-set="x_icon" t-value="'/palmpos_theme/static/img/logo.webp'" />
        </xpath>
    </template>

    <!-- Login Page - Change Email to Username -->
    <template id="login_username" inherit_id="web.login" name="Login Username Label">
        <!-- Change Email label to Username -->
        <xpath expr="//label[@for='login']" position="replace">
            <label for="login" class="form-label d-flex justify-content-between">Username</label>
        </xpath>
        <!-- Change placeholder text -->
        <xpath expr="//input[@name='login']" position="attributes">
            <attribute name="placeholder">Enter your username</attribute>
        </xpath>
    </template>
</odoo>
