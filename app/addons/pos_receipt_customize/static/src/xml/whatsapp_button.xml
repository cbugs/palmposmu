<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Add WhatsApp button to ReceiptScreen -->
    <t t-name="point_of_sale.ReceiptScreen" t-inherit="point_of_sale.ReceiptScreen" t-inherit-mode="extension">
        <xpath expr="//div[@class='button-container']" position="inside">
            <button class="btn btn-success btn-send-whatsapp" t-on-click="() => this.sendWhatsApp()">
                <i class="fa fa-whatsapp"></i> Send via WhatsApp
            </button>
        </xpath>
    </t>

</templates>
